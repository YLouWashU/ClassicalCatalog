<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} — Classical Catalog</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600&family=EB+Garamond:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg:          #0d0b09;
      --surface:     #161210;
      --surface2:    #1e1a16;
      --gold:        #c9a56a;
      --gold-dim:    rgba(201,165,106,0.12);
      --gold-border: rgba(201,165,106,0.25);
      --cream:       #ede4d4;
      --muted:       #7a6a58;
      --border:      #2a2420;
      --green:       #1DB954;
      --text-body:   #cdc0b0;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'EB Garamond', Georgia, serif;
      background: var(--bg);
      color: var(--cream);
      min-height: 100vh;
      font-size: 17px;
    }

    /* ── Header ── */
    .site-header {
      background: #090706;
      border-bottom: 1px solid var(--border);
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .header-top {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.75rem 2rem;
      border-bottom: 1px solid var(--border);
    }

    .back-link {
      color: var(--muted);
      text-decoration: none;
      font-size: 0.78rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      transition: color 0.15s;
    }
    .back-link:hover { color: var(--gold); }

    .lang-switch a {
      color: var(--gold);
      text-decoration: none;
      font-size: 0.78rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      border-bottom: 1px solid var(--gold-border);
      padding-bottom: 1px;
      transition: border-color 0.15s;
    }
    .lang-switch a:hover { border-color: var(--gold); }

    .header-body {
      padding: 1rem 2rem 0;
    }

    .issue-eyebrow {
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.18em;
      color: var(--gold);
      margin-bottom: 0.2rem;
    }

    .issue-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.75rem;
      font-weight: 700;
      color: var(--cream);
      letter-spacing: 0.01em;
      line-height: 1.15;
    }

    /* ── Tabs ── */
    .tabs-bar {
      display: flex;
      overflow-x: auto;
      padding: 0 2rem;
      margin-top: 0.9rem;
      scrollbar-width: none;
      gap: 0;
    }
    .tabs-bar::-webkit-scrollbar { display: none; }

    .tab-btn {
      background: none;
      border: none;
      border-bottom: 2px solid transparent;
      color: var(--muted);
      font-family: 'EB Garamond', serif;
      font-size: 0.88rem;
      letter-spacing: 0.06em;
      padding: 0.55rem 1.1rem 0.55rem;
      cursor: pointer;
      white-space: nowrap;
      transition: color 0.2s, border-color 0.2s;
      display: flex;
      align-items: center;
      gap: 0.45rem;
    }
    .tab-btn:hover { color: var(--cream); }
    .tab-btn.active {
      color: var(--gold);
      border-bottom-color: var(--gold);
    }

    .tab-count {
      font-size: 0.7rem;
      background: var(--gold-dim);
      color: var(--gold);
      padding: 0.05rem 0.45rem;
      border-radius: 999px;
      font-style: normal;
    }

    /* ── Main content ── */
    main {
      max-width: 940px;
      margin: 0 auto;
      padding: 2rem 1.5rem 5rem;
    }

    .tab-panel { display: none; }
    .tab-panel.active { display: block; }

    /* ── Recording card ── */
    .recording-card {
      display: grid;
      grid-template-columns: 130px 1fr;
      gap: 1.6rem;
      padding: 1.75rem 0;
      border-bottom: 1px solid var(--border);
    }
    .recording-card:last-child { border-bottom: none; }
    .recording-card.animate {
      animation: cardIn 0.35s ease both;
    }

    @keyframes cardIn {
      from { opacity: 0; transform: translateY(10px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .art-col { position: relative; }

    .album-art {
      width: 130px;
      height: 130px;
      object-fit: cover;
      border-radius: 3px;
      display: block;
      transition: transform 0.22s ease, box-shadow 0.22s ease;
    }
    .album-art:hover {
      transform: scale(1.04);
      box-shadow: 0 10px 30px rgba(0,0,0,0.7), 0 0 0 1px var(--gold-border);
    }

    .art-placeholder {
      width: 130px;
      height: 130px;
      background: var(--surface2);
      border-radius: 3px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--border);
      font-size: 2.5rem;
    }

    .card-content {}

    .card-badges {
      display: flex;
      gap: 0.5rem;
      margin-bottom: 0.6rem;
      min-height: 1.4rem;
    }

    .badge-rotm {
      font-size: 0.68rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      background: var(--gold);
      color: #0d0b09;
      padding: 2px 9px;
      border-radius: 2px;
      font-weight: 700;
      font-style: normal;
    }

    .badge-ec {
      font-size: 0.68rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      border: 1px solid var(--gold-border);
      color: var(--gold);
      padding: 2px 9px;
      border-radius: 2px;
    }

    .card-composer {
      font-size: 0.78rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--gold);
      margin-bottom: 0.2rem;
    }

    .card-work {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.35rem;
      font-weight: 700;
      color: var(--cream);
      line-height: 1.2;
      margin-bottom: 0.35rem;
    }

    .card-performers {
      font-size: 0.92rem;
      color: var(--muted);
      font-style: italic;
      margin-bottom: 0.9rem;
      line-height: 1.4;
    }

    .card-tldr {
      font-size: 1rem;
      line-height: 1.75;
      color: var(--text-body);
      margin-bottom: 1rem;
    }

    /* ── Spotify buttons ── */
    .card-actions {
      display: flex;
      gap: 0.6rem;
      align-items: center;
      margin-bottom: 0.9rem;
      flex-wrap: wrap;
    }

    .btn-app {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      background: var(--green);
      color: #000;
      text-decoration: none;
      font-size: 0.78rem;
      font-weight: 700;
      padding: 0.38rem 1rem;
      border-radius: 999px;
      letter-spacing: 0.04em;
      transition: filter 0.15s;
    }
    .btn-app:hover { filter: brightness(1.12); }
    .btn-app svg { width: 12px; height: 12px; fill: #000; }

    .btn-web {
      display: inline-flex;
      align-items: center;
      color: var(--muted);
      text-decoration: none;
      font-size: 0.78rem;
      border: 1px solid var(--border);
      padding: 0.38rem 0.85rem;
      border-radius: 999px;
      letter-spacing: 0.04em;
      transition: color 0.15s, border-color 0.15s;
    }
    .btn-web:hover { color: var(--cream); border-color: var(--muted); }

    .no-spotify {
      font-size: 0.82rem;
      color: var(--muted);
      font-style: italic;
    }

    /* ── Comparisons ── */
    .comparisons {
      border-top: 1px solid var(--border);
      padding-top: 0.8rem;
    }

    .comp-label {
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.13em;
      color: var(--muted);
      margin-bottom: 0.6rem;
    }

    .comp-item {
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
      padding: 0.35rem 0;
    }

    .comp-art {
      width: 38px;
      height: 38px;
      object-fit: cover;
      border-radius: 2px;
      flex-shrink: 0;
    }

    .comp-art-placeholder {
      width: 38px;
      height: 38px;
      background: var(--surface2);
      border-radius: 2px;
      flex-shrink: 0;
    }

    .comp-text { flex: 1; min-width: 0; }

    .comp-work {
      font-size: 0.9rem;
      color: var(--cream);
      line-height: 1.3;
    }

    .comp-meta {
      font-size: 0.82rem;
      color: var(--muted);
      font-style: italic;
      margin-top: 0.1rem;
    }

    .comp-spotify {
      color: var(--green);
      text-decoration: none;
      font-size: 0.8rem;
      margin-left: 0.4rem;
      opacity: 0.8;
      transition: opacity 0.15s;
    }
    .comp-spotify:hover { opacity: 1; }

    /* ── Features ── */
    .feature-block {
      background: var(--surface);
      border-left: 3px solid var(--gold);
      border-radius: 0 4px 4px 0;
      padding: 1.5rem 1.75rem;
      margin-bottom: 2rem;
    }

    .feature-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.45rem;
      font-weight: 700;
      color: var(--cream);
      margin-bottom: 0.75rem;
    }

    .feature-summary {
      font-size: 1rem;
      line-height: 1.8;
      color: var(--text-body);
      font-style: italic;
      margin-bottom: 1.25rem;
      border-bottom: 1px solid var(--border);
      padding-bottom: 1.25rem;
    }

    .feature-recordings .recording-card {
      grid-template-columns: 90px 1fr;
    }
    .feature-recordings .album-art,
    .feature-recordings .art-placeholder {
      width: 90px;
      height: 90px;
    }

    /* ── Responsive ── */
    @media (max-width: 600px) {
      .recording-card { grid-template-columns: 80px 1fr; gap: 1rem; }
      .album-art, .art-placeholder { width: 80px; height: 80px; }
      .header-body { padding: 0.75rem 1rem 0; }
      .header-top { padding: 0.6rem 1rem; }
      .tabs-bar { padding: 0 1rem; }
      main { padding: 1.5rem 1rem 4rem; }
    }
  </style>
</head>
<body>

<header class="site-header">
  <div class="header-top">
    <a href="../../index.html" class="back-link">← All Issues</a>
    <span class="lang-switch"><a href="../../../zh/issues/{{ issue_key }}/index.html">中文</a></span>
  </div>
  <div class="header-body">
    <div class="issue-eyebrow">Gramophone</div>
    <h1 class="issue-title">{{ title }}</h1>
  </div>
  <nav class="tabs-bar" role="tablist" aria-label="Sections">
    {% for section in sections %}
    <button class="tab-btn{% if loop.first %} active{% endif %}"
            data-tab="tab-{{ section.key }}"
            role="tab"
            aria-selected="{{ 'true' if loop.first else 'false' }}">
      {{ section.label }}<span class="tab-count">{{ section.recordings | length }}</span>
    </button>
    {% endfor %}
    {% if features %}
    <button class="tab-btn{% if not sections %} active{% endif %}"
            data-tab="tab-features"
            role="tab"
            aria-selected="{{ 'true' if not sections else 'false' }}">
      Features<span class="tab-count">{{ features | length }}</span>
    </button>
    {% endif %}
  </nav>
</header>

<main>

  {% for section in sections %}
  <div class="tab-panel{% if loop.first %} active{% endif %}"
       id="tab-{{ section.key }}"
       role="tabpanel">
    {% for rec in section.recordings %}
    {% if rec.spotify_url %}
      {% set album_id = rec.spotify_url.split('/album/')[1].split('?')[0] %}
    {% endif %}
    <div class="recording-card animate" style="animation-delay:{{ loop.index0 * 0.06 }}s">

      <div class="art-col">
        {% if rec.album_image_url %}
        <img class="album-art" src="{{ rec.album_image_url }}" alt="{{ rec.work }}" loading="lazy">
        {% else %}
        <div class="art-placeholder">♪</div>
        {% endif %}
      </div>

      <div class="card-content">
        <div class="card-badges">
          {% if rec.badge == "recording_of_the_month" %}
          <span class="badge-rotm">Recording of the Month</span>
          {% elif rec.badge == "editors_choice" %}
          <span class="badge-ec">Editor's Choice</span>
          {% endif %}
        </div>
        <div class="card-composer">{{ rec.composer }}</div>
        <h2 class="card-work">{{ rec.work }}</h2>
        <div class="card-performers">
          {{ rec.performers }}{% if rec.label %} &middot; {{ rec.label }}{% endif %}{% if rec.catalog %} &middot; {{ rec.catalog }}{% endif %}
        </div>
        <div class="card-tldr">{{ rec.tldr }}</div>

        <div class="card-actions">
          {% if rec.spotify_url %}
          <a href="spotify:album:{{ album_id }}" class="btn-app">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/></svg>
            Open in Spotify
          </a>
          <a href="{{ rec.spotify_url }}" target="_blank" rel="noopener" class="btn-web">Web Player</a>
          {% else %}
          <span class="no-spotify">Not on Spotify</span>
          {% endif %}
        </div>

        {% if rec.comparison_recordings %}
        <div class="comparisons">
          <div class="comp-label">Also consider</div>
          {% for comp in rec.comparison_recordings %}
          {% if comp.spotify_url %}
            {% set comp_id = comp.spotify_url.split('/album/')[1].split('?')[0] %}
          {% endif %}
          <div class="comp-item">
            {% if comp.album_image_url %}
            <img class="comp-art" src="{{ comp.album_image_url }}" alt="" loading="lazy">
            {% else %}
            <div class="comp-art-placeholder"></div>
            {% endif %}
            <div class="comp-text">
              <div class="comp-work">
                {{ comp.composer }} — {{ comp.work }}
                {% if comp.spotify_url %}
                <a href="spotify:album:{{ comp_id }}" class="comp-spotify" title="Open in Spotify">▶</a>
                {% endif %}
              </div>
              <div class="comp-meta">
                {{ comp.performers }}{% if comp.label %} &middot; {{ comp.label }}{% endif %}
              </div>
            </div>
          </div>
          {% endfor %}
        </div>
        {% endif %}

      </div>
    </div>
    {% endfor %}
  </div>
  {% endfor %}

  {% if features %}
  <div class="tab-panel{% if not sections %} active{% endif %}"
       id="tab-features"
       role="tabpanel">
    {% for feat in features %}
    <div class="feature-block">
      <h2 class="feature-title">{{ feat.title }}</h2>
      <div class="feature-summary">{{ feat.summary }}</div>
      <div class="feature-recordings">
        {% for rec in feat.recordings %}
        {% if rec.spotify_url %}
          {% set album_id = rec.spotify_url.split('/album/')[1].split('?')[0] %}
        {% endif %}
        <div class="recording-card animate" style="animation-delay:{{ loop.index0 * 0.06 }}s">
          <div class="art-col">
            {% if rec.album_image_url %}
            <img class="album-art" src="{{ rec.album_image_url }}" alt="{{ rec.work }}" loading="lazy">
            {% else %}
            <div class="art-placeholder">♪</div>
            {% endif %}
          </div>
          <div class="card-content">
            <div class="card-composer">{{ rec.composer }}</div>
            <h3 class="card-work">{{ rec.work }}</h3>
            <div class="card-performers">
              {{ rec.performers }}{% if rec.label %} &middot; {{ rec.label }}{% endif %}
            </div>
            <div class="card-tldr">{{ rec.tldr }}</div>
            <div class="card-actions">
              {% if rec.spotify_url %}
              <a href="spotify:album:{{ album_id }}" class="btn-app">
                <svg viewBox="0 0 24 24"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/></svg>
                Open in Spotify
              </a>
              <a href="{{ rec.spotify_url }}" target="_blank" rel="noopener" class="btn-web">Web Player</a>
              {% else %}
              <span class="no-spotify">Not on Spotify</span>
              {% endif %}
            </div>
          </div>
        </div>
        {% endfor %}
      </div>
    </div>
    {% endfor %}
  </div>
  {% endif %}

</main>

<script>
  const tabBtns = document.querySelectorAll('.tab-btn');
  const tabPanels = document.querySelectorAll('.tab-panel');

  tabBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      tabBtns.forEach(b => { b.classList.remove('active'); b.setAttribute('aria-selected', 'false'); });
      tabPanels.forEach(p => p.classList.remove('active'));

      btn.classList.add('active');
      btn.setAttribute('aria-selected', 'true');

      const panel = document.getElementById(btn.dataset.tab);
      if (panel) {
        panel.classList.add('active');
        // Re-trigger animations
        panel.querySelectorAll('.recording-card').forEach((card, i) => {
          card.classList.remove('animate');
          void card.offsetWidth; // reflow
          card.style.animationDelay = (i * 0.06) + 's';
          card.classList.add('animate');
        });
      }
    });
  });
</script>

</body>
</html>
